generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Url {
  id           Int       @id @default(autoincrement())
  original_url String
  short_code   String    @unique @db.VarChar(10)
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  expires_on   DateTime? @default(dbgenerated("(CURRENT_TIMESTAMP + '7 days'::interval)")) @db.Timestamp(6)

  @@map("urls")
}
